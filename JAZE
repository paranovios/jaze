import javax.swing.*;
import java.awt.*;
import java.awt.event.*;

public class JazeTerminal extends JFrame {

    private final String[] frases = {
        "Mi vida, ahora ya no gira",
        "Y es que en verdad, ya no puedo más",
        "Sé que tú también estás cansada",
        "Entendí que lo nuestro ya no va",
        "Y aunque duela, tengo que soltar",
        "Porque a veces amar, es dejar ir"
    };

    private int indice = 0;
    private JLabel lblTexto;

    public JazeTerminal() {
        setTitle("Jaze - la terminal");
        setSize(400, 180);
        setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        setLocationRelativeTo(null);
        setResizable(false);

        JPanel panel = new JPanel(new BorderLayout(10, 10));
        panel.setBorder(BorderFactory.createEmptyBorder(15, 15, 15, 15));

        lblTexto = new JLabel(frases[indice], SwingConstants.CENTER);
        lblTexto.setFont(new Font("Segoe UI", Font.PLAIN, 14));
        panel.add(lblTexto, BorderLayout.CENTER);

        JButton btn = new JButton("OK");
        btn.addActionListener(e -> {
            indice = (indice + 1) % frases.length;
            lblTexto.setText(frases[indice]);
        });

        panel.add(btn, BorderLayout.SOUTH);

        add(panel);
        setVisible(true);
    }

    public static void main(String[] args) {
        SwingUtilities.invokeLater(JazeTerminal::new);
    }
}
